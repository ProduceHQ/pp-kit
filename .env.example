# Supabase — get these from your project's Settings > API page
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Shared team passcode — shown on the lock screen before the app loads
VITE_ACCESS_CODE=your-team-passcode

# Only needed for the one-time seed script (never put this in Vercel)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
